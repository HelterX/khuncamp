{
  "$schema": "node_modules/wrangler/config-schema.json",

  "name": "khuncamp",
  "compatibility_date": "2026-03-30",

  "env": {
    "production": {
      "name": "khuncamp-prod",
      "routes": [
        {
          "pattern": "khuncamp.com/*",
          "zone_name": "khuncamp.com"
        }
      ]
    },
    "staging": {
      "name": "khuncamp-staging"
    }
  },

  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  }
}
